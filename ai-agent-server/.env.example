# -----------------------------------------------------------------------
# LLM 전략 (환경변수 하나로 전환)
# 개발/테스트: CLAUDE_API  — 하이브리드 라우팅 (민감 로그 → Qwen3 시도 → Claude 폴백)
# 데모 당일:   QWEN_LOCAL  — 모든 트래픽 → vLLM (Qwen3)
# -----------------------------------------------------------------------
LLM_PROVIDER=CLAUDE_API

# Claude API (LLM_PROVIDER=CLAUDE_API 일 때 사용)
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxx
CLAUDE_MODEL=claude-sonnet-4-6

# vLLM — Qwen3:4B 상시 모델 (로그/메트릭 감시)
VLLM_BASE_URL=http://localhost:8001
VLLM_4B_MODEL=Qwen/Qwen3-4B

# vLLM — Qwen3:8B 정밀 분석 모델 (CRITICAL 시 K8s Pod 교체로 실행)
VLLM_DEEP_URL=http://vllm-8b-service.ai-agents.svc.cluster.local:8002
VLLM_30B_MODEL=Qwen/Qwen3-8B

LLM_TIMEOUT_SECONDS=120

# Loki (로그 수집)
LOKI_URL=http://localhost:3100
LOKI_LOG_QUERY={job="app_logs"}

# Prometheus (메트릭 수집)
PROMETHEUS_URL=http://localhost:9090

# 모니터링 설정
POLL_INTERVAL_SECONDS=30
LOG_LOOKBACK_MINUTES=5

# Slack 알림 (선택 — 없으면 알림 스킵)
SLACK_WEBHOOK_URL=

# Aurora PostgreSQL (분석 이력 저장)
AURORA_HOST=your-cluster.cluster-xxxx.ap-northeast-2.rds.amazonaws.com
AURORA_PORT=5432
AURORA_DB=ai_agent
AURORA_USER=postgres
AURORA_PASSWORD=your_password_here

# Kafka
KAFKA_BOOTSTRAP_SERVERS=kafka-service.ai-agents.svc.cluster.local:9092
KAFKA_TOPIC_CRITICAL=critical-anomalies
KAFKA_CONSUMER_GROUP=deep-analysis-group

# Kubernetes GPU 스케줄링
K8S_NAMESPACE=ai-agents
K8S_VLLM_4B_DEPLOYMENT=vllm-4b
K8S_VLLM_8B_DEPLOYMENT=vllm-8b
K8S_ENABLED=true   # 로컬 개발 시 false, K8s 배포 시 true

# Server
HOST=0.0.0.0
PORT=8000
